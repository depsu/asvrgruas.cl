# Cloudflare — cabeceras (Workers Static Assets)

# Recursos estáticos (imágenes y videos): cache en el navegador.
# stale-while-revalidate: usa la copia guardada mientras refresca en segundo plano.
/imagenes/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/favicon.svg
  Cache-Control: public, max-age=86400

# Las landings de Ads no se indexan en buscadores (AdsBot las rastrea igual,
# no afecta el Quality Score). Jamás bloquear AdsBot-Google en robots.txt.
# El HTML NO se cachea en el navegador: así los cambios se ven de inmediato.
/lp/*
  X-Robots-Tag: noindex, nofollow

# Panel del cliente (páginas + UI compartida): SIEMPRE revalidar antes de usar la copia.
# Con ETag la revalidación es un 304 baratísimo, así que sigue cargando rápido.
# LECCIÓN (destapando, jul-2026): nada de stale-while-revalidate aquí (mostraba versiones
# viejas y mezcladas) y rutas explícitas (no /panel*) para no pisar a panel-ui.js.
/panel-ui.js
  Cache-Control: no-cache

